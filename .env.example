# Copy to .env and adjust if needed:
#   cp .env.example .env

# GCP project used for google_cloud_default connection (set to your real project for GCP DAGs)
GCP_PROJECT_ID=local-dev

# Host ports
AIRFLOW_PORT=8080
POSTGRES_PORT=25432

# Optional: override gcloud credentials path (default: ~/.config/gcloud)
# GCLOUD_CONFIG_PATH=/path/to/gcloud/config

# Google AI Studio API key for @task.llm (llm_conn_id="google_ai")
# Used by: dag1_sample_ai.py (ai_test), dag2_ai_spam_filter.py (ai_spam_filter)
# Get one at: https://aistudio.google.com/apikey
# Wired in docker-compose.yml as AIRFLOW_CONN_GOOGLE_AI — restart container after changing
GOOGLE_AI_API_KEY=
